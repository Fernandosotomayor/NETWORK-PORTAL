# ==============================================================================
# STLi Network Portal - Plantilla de Variables de Entorno (.env.example)
# Copia este archivo a `.env` y ajusta los valores según corresponda.
# ==============================================================================

# Entorno y Depuración
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000

# Directorios de la Aplicación (Rutas Relativas al Proyecto o Absolutas)
DATA_DIR=normalized_json
STATIC_DIR=app/static
TEMPLATES_DIR=app/templates
BACKUPS_GIT_DIR=backups
OXIDIZED_URL=http://10.40.20.70:8888

